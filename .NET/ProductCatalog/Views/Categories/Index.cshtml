@model IEnumerable<ProductCatalog.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Category List</h1>
        <p>
            <a asp-action="Create" class="btn btn-primary shadow-sm">Create New Category</a>
        </p>
    </div>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>@Html.DisplayNameFor(model => model.Description)</th>
                <th>Preview</th> <!-- Updated header for Image -->
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@Html.DisplayFor(modelItem => item.Name)</td>
                    <td>@Html.DisplayFor(modelItem => item.Description)</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <!-- This renders the actual image instead of the text path -->
                            <img src="@item.ImageUrl"
                                 alt="@item.Name"
                                 class="rounded shadow-sm"
                                 style="width: 80px; height: 60px; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="text-muted small">No Image</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>