@model ProductCatalog.Models.Product

<div class="container mt-5">
    <div class="card mx-auto shadow" style="max-width: 550px;">

        <img src="@Model.ImageUrl"
             class="card-img-top mx-auto mt-4"
             style="width: 200px; height: 200px; object-fit: cover;" />

        <div class="card-body text-center">
            <h3 class="card-title fw-bold">@Model.Name</h3>
            <hr />
            <p class="card-text text-muted">@Model.Description</p>
            <p class="fs-5">
                <strong>Price:</strong>
                <span class="text-success fw-bold">$@Model.Price</span>
            </p>
            <a asp-controller="Products" asp-action="ByCategory" asp-route-id="@Model.CategoryId" class="btn btn-secondary mt-2">← Back to Products</a>
        </div>

    </div>
</div>