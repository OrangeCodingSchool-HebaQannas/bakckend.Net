@using tuples.Models
@model Tuple<Student, Course>


@{
    ViewData["Title"] = "Student & Course Details";
}

<h2>Task: Passing Mutliple Models via Tuples</h2>

<hr/>

<div class="row">
    <!-- Student Information -->
    <div class="col-md-6">
        <h3>Student Information</h3>
        <p><strong>ID:</strong> @Model.Item1.Id</p>
        <p><strong>Name:</strong> @Model.Item1.Name</p>
        <p><strong>Age:</strong> @Model.Item1.Age</p>
    </div>

    <!-- Course Information -->
    <div class="col-md-6">
        <h3>Course Information</h3>
        <p><strong>Course ID:</strong> @Model.Item2.Id</p>
        <p><strong>Course Name:</strong> @Model.Item2.CourseName</p>
        <p><strong>Instructor:</strong> @Model.Item2.InstructorName</p>
    </div>
</div>